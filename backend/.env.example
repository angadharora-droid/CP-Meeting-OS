# Backend env
PORT=4000
# Optional keep-alive ping for hosted deployments.
# Set KEEP_ALIVE_URL to your public backend URL, not localhost.
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_URL=https://your-backend.example.com
KEEP_ALIVE_INTERVAL_MS=300000

# No-Docker option (MongoDB Atlas):
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/meeting_os?retryWrites=true&w=majority
# Optional fallback if MONGO_URI does not include /database-name:
MONGO_DB_NAME=meeting_os

# Local MongoDB option:
# MONGO_URI=mongodb://localhost:27017/meeting_os

# Admin User Configuration
ADMIN_NAME=Angadh Arora
ADMIN_EMAIL=admin@gmail.com
ADMIN_PIN=131313

# Google Calendar Integration (optional)
# Create a Service Account in Google Cloud Console, enable Calendar API,
# then download the JSON key and copy the values below.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (including \n line breaks) from the JSON key file
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# Leave as 'primary' to use the service account's own calendar, or paste a specific calendar ID
GOOGLE_CALENDAR_ID=primary
# IANA timezone for all meeting events (default: Asia/Dhaka)
MEETING_TIMEZONE=Asia/Dhaka

# Email / iCal Invite — sends calendar invites directly to manager attendees
# Use a Gmail App Password (NOT your regular password).
# Create one at: myaccount.google.com/apppasswords (requires 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=Meeting OS

# Google OAuth (per-user direct calendar push — no domain-wide delegation needed)
# Create "OAuth 2.0 Client ID" credentials (Web application type) at console.cloud.google.com
# Add authorized redirect URI: http://your-backend/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/auth/google/callback
# URL of the frontend app — used to redirect after OAuth
FRONTEND_URL=http://localhost:5173
# Comma-separated origins allowed to call this API from browsers.
# Leave empty for local/open development, set in production.
CORS_ORIGINS=http://localhost:5173,https://meetingos.centrepointgroup.in
